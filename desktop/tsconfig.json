{
  "files": [],
  "references": [{ "path": "./tsconfig.node.json" }, { "path": "./tsconfig.web.json" }],
  // bun test resolves the "@/" alias from the nearest tsconfig; tsc uses
  // the referenced projects and electron-vite its own resolve.alias.
  "compilerOptions": {
    "baseUrl": ".",
    "paths": {
      "@/*": ["src/renderer/src/*"]
    }
  }
}
